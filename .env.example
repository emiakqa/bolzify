# Supabase — hole diese Werte aus deinem Supabase-Projekt:
# Project Settings → API → Project URL + anon/public key
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# api-football.com — API-Key holst du auf api-football.com/pricing
# (noch nicht nötig für Tag 1, kommt in Woche 1 Tag 4)
# API_FOOTBALL_KEY=
