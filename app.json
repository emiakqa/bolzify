{
  "expo": {
    "name": "Bolzify",
    "slug": "bolzify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bolzify",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "primaryColor": "#22c55e",
    "owner": "[EXPO_USERNAME]",
    "extra": {
      "eas": {
        "projectId": "[EAS_PROJECT_ID]"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/[EAS_PROJECT_ID]"
    },
    "ios": {
      "bundleIdentifier": "de.bolzify.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Bolzify braucht Zugriff auf deine Fotos, damit du ein Profilbild auswählen kannst.",
        "NSCameraUsageDescription": "Bolzify nutzt die Kamera nicht — diese Beschreibung wird nur bei Bedarf angezeigt.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "de.bolzify.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Bolzify braucht Zugriff auf deine Fotos, damit du ein Profilbild auswählen kannst.",
          "cameraPermission": "Bolzify nutzt die Kamera aktuell nicht."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#22c55e",
          "defaultChannel": "tip-reminders"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
